    "import cv2 as cv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "44529745",
   "metadata": {},
   "outputs": [],
   "source": [
    "vid = cv.VideoCapture(0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "80cc8456",
   "metadata": {},
   "outputs": [],
   "source": [
    "while True:\n",
    "  try:\n",
    "    res, frame = vid.read()\n",
    "    cv.imshow(\"Hand Gestures\", frame)\n",
    "  except:\n",
    "    pass\n",
    "\n",
    "  if cv.waitKey(1) & 0xff==ord(\"q\"):\n",
    "    break\n",
    "\n",
    "cv.destroyAllWindows()"
   ]
